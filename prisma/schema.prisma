// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 应用模式枚举
enum AppMode {
  EXTERNAL    // 外部版
  INTERNAL    // 蚂蚁内部版
  BOTH        // 两者皆可
}

// 会议状态枚举
enum MeetingStatus {
  PENDING        // 等待处理
  UPLOADING      // 上传中
  TRANSCRIBING   // 转写中
  SUMMARIZING    // 生成纪要中
  COMPLETED      // 已完成
  FAILED         // 失败
}

// 会议记录主表
model Meeting {
  id          String   @id @default(cuid())
  title       String   @default("未命名会议")

  // 音频文件信息
  audioPath   String?  @map("audio_path")         // 音频文件存储路径
  audioSize   Int?     @map("audio_size")         // 文件大小（字节）
  audioFormat String?  @map("audio_format")       // 文件格式 (mp3, wav, m4a等)
  duration    Int?                                 // 音频时长（秒）

  // 处理状态
  status      MeetingStatus @default(PENDING)
  progress    Int           @default(0)            // 处理进度 0-100
  errorMessage String?      @map("error_message")  // 错误信息

  // 用户关联
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 时间戳
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 关联关系
  transcription Transcription?
  summary       Summary?
  history       MeetingHistory?

  @@map("meetings")
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

// 转写结果表
model Transcription {
  id         String   @id @default(cuid())
  meetingId  String   @unique @map("meeting_id")
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // 转写内容
  fullText   String   @map("full_text")             // 完整逐字稿
  segments   Json?                                   // 分段数据 (时间轴 + 文本)
  language   String?                                 // 检测到的语言

  // 元数据
  wordCount  Int?     @map("word_count")            // 字数统计
  confidence Float?                                  // 平均置信度
  model      String   @default("whisper-1")         // 使用的模型

  // 时间戳
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("transcriptions")
  @@index([meetingId])
}

// 会议纪要表
model Summary {
  id           String   @id @default(cuid())
  meetingId    String   @unique @map("meeting_id")
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // 纪要内容
  content      String                               // 完整会议纪要 (Markdown格式)
  keyPoints    Json?    @map("key_points")          // 关键要点数组
  actionItems  Json?    @map("action_items")        // 待办事项数组
  participants Json?                                // 参与者列表 (如果能识别)
  tags         Json?                                // 标签/关键词（JSON 数组）

  // 元数据
  model        String   @default("claude-3-5-sonnet") // 使用的模型
  tokensUsed   Int?     @map("tokens_used")         // Token使用量

  // 时间戳
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("summaries")
  @@index([meetingId])
}

// 历史记录表
model MeetingHistory {
  id              String   @id @default(cuid())
  meetingId        String   @unique @map("meeting_id")
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // 文件上传信息
  uploadDate       DateTime @default(now()) @map("upload_date")  // 文件上传日期
  uploadTime       DateTime @default(now()) @map("upload_time")  // 文件上传时间
  fileName         String   @map("file_name")                   // 上传的文件名称

  // 纪要生成信息
  summaryDate      DateTime? @map("summary_date")               // 纪要生成日期
  summaryTime      DateTime? @map("summary_time")               // 纪要生成时间
  summaryContent   String?   @map("summary_content") @db.Text   // 生成的纪要内容

  // 时间戳
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("meeting_histories")
  @@index([meetingId])
  @@index([uploadDate])
}

// ========== 用户系统 ==========

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String?

  isActive      Boolean  @default(true) @map("is_active")

  // 蚂蚁内部版：用户的 Theta API KEY（加密存储）
  thetaApiKey   String?  @map("theta_api_key")

  // 用户偏好的默认模式
  preferredMode AppMode  @default(EXTERNAL) @map("preferred_mode")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  vocabularies  UserVocabulary[]
  templates     UserTemplate[]
  meetings      Meeting[]

  @@map("users")
  @@index([email])
}

model UserVocabulary {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  words       Json     @default("[]")
  wordCount   Int      @default(0) @map("word_count")

  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")

  // 可用模式：EXTERNAL=仅外部版, INTERNAL=仅内部版, BOTH=两者皆可
  availableMode AppMode @default(BOTH) @map("available_mode")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_vocabularies")
  @@index([userId])
}

model UserTemplate {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  content     String   @db.Text

  category    String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  usageCount  Int      @default(0) @map("usage_count")

  // 可用模式：EXTERNAL=仅外部版, INTERNAL=仅内部版, BOTH=两者皆可
  availableMode AppMode @default(BOTH) @map("available_mode")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_templates")
  @@index([userId])
}
