generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id            String          @id @default(cuid())
  title         String          @default("未命名会议")
  audioPath     String?         @map("audio_path")
  audioSize     Int?            @map("audio_size")
  audioFormat   String?         @map("audio_format")
  duration      Int?
  status        MeetingStatus   @default(PENDING)
  progress      Int             @default(0)
  errorMessage  String?         @map("error_message")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  userId        String?         @map("user_id")
  history       MeetingHistory?
  user          User?           @relation(fields: [userId], references: [id])
  summary       Summary?
  transcription Transcription?

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@map("meetings")
}

model Transcription {
  id         String   @id @default(cuid())
  meetingId  String   @unique @map("meeting_id")
  fullText   String   @map("full_text")
  segments   Json?
  language   String?
  wordCount  Int?     @map("word_count")
  confidence Float?
  model      String   @default("whisper-1")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // 发言人名称映射 { "0": "张三", "1": "李四" }
  speakerMap  Json?     @map("speaker_map")
  // 最后纠错时间
  correctedAt DateTime? @map("corrected_at")

  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("transcriptions")
}

model Summary {
  id               String   @id @default(cuid())
  meetingId        String   @unique @map("meeting_id")
  content          String
  keyPoints        Json?    @map("key_points")
  actionItems      Json?    @map("action_items")
  participants     Json?
  tags             Json?
  model            String   @default("claude-3-5-sonnet")
  tokensUsed       Int?     @map("tokens_used")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  generation_count Int      @default(1)
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("summaries")
}

model MeetingHistory {
  id             String    @id @default(cuid())
  meetingId      String    @unique @map("meeting_id")
  uploadDate     DateTime  @default(now()) @map("upload_date")
  uploadTime     DateTime  @default(now()) @map("upload_time")
  fileName       String    @map("file_name")
  summaryDate    DateTime? @map("summary_date")
  summaryTime    DateTime? @map("summary_time")
  summaryContent String?   @map("summary_content")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  meeting        Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([uploadDate])
  @@map("meeting_histories")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String           @map("password_hash")
  name           String?
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  lastLoginAt    DateTime?        @map("last_login_at")
  preferred_mode AppMode          @default(EXTERNAL)
  theta_api_key  String?
  meetings       Meeting[]
  templates      UserTemplate[]
  vocabularies   UserVocabulary[]

  @@index([email])
  @@map("users")
}

model UserVocabulary {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  description    String?
  words          Json     @default("[]")
  wordCount      Int      @default(0) @map("word_count")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  available_mode AppMode  @default(BOTH)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_vocabularies")
}

model UserTemplate {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  description    String?
  content        String
  category       String?
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  usageCount     Int      @default(0) @map("usage_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  available_mode AppMode  @default(BOTH)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_templates")
}

enum MeetingStatus {
  PENDING
  UPLOADING
  TRANSCRIBING
  SUMMARIZING
  COMPLETED
  FAILED
}

enum AppMode {
  EXTERNAL
  INTERNAL
  BOTH
}
