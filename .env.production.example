# ========================================
# Database Configuration
# ========================================
# SQLite 数据库文件 (开发环境)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL 连接字符串 (Docker Compose) - 备用
# DATABASE_URL="postgresql://deepdivenote:deepdivenote_dev_password@localhost:5432/deepdivenote?schema=public"

# ========================================
# Redis Configuration (for BullMQ)
# ========================================
REDIS_URL="redis://localhost:6379"

# ========================================
# AI Service API Keys
# ========================================
# 阿里云通义千问 ASR API (语音转文字)
# 获取API Key: https://dashscope.console.aliyun.com/
QWEN_API_KEY="your key"

# Anthropic API Key (用于 Claude 生成会议纪要)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ZenMux API Key (用于 GPT-5.4-Mini 文字稿纠错)
ZENMUX_API_KEY="your key"

# ========================================
# 阿里云 OSS 配置
# ========================================
ALIYUN_ACCESS_KEY_ID="your id"
ALIYUN_ACCESS_KEY_SECRET="your secret"
ALIYUN_OSS_REGION="oss-cn-beijing"
ALIYUN_OSS_BUCKET="deepdivenote"
ALIYUN_OSS_ENDPOINT="oss-cn-beijing.aliyuncs.com"

# ========================================
# Application Settings
# ========================================
# Next.js 运行端口
PORT=3000

# 文件上传配置
MAX_FILE_SIZE=2147483648  # 2GB (6小时高质量音频)
UPLOAD_DIR="./uploads"

# ========================================
# Optional: Feature Flags
# ========================================
# 启用调试日志
DEBUG=false

# 启用实验性功能
ENABLE_EXPERIMENTAL_FEATURES=false